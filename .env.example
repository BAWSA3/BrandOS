# Copy this file to .env.local and fill in your values
# IMPORTANT: Never commit .env or .env.local files to git!

# ===========================================
# Supabase Configuration (Required for Auth)
# ===========================================
# Get these from your Supabase dashboard: Settings > API
# These NEXT_PUBLIC_ values are safe to expose to the browser (they are public keys)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Supabase Database (PostgreSQL)
# Get these from your Supabase dashboard: Settings > Database > Connection String
# Direct connection (for migrations) - uses port 5432
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"
# Pooled connection (for serverless/Vercel runtime) - uses port 6543 with pgbouncer
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ===========================================
# AI Services
# ===========================================
# Anthropic API (Core AI features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gemini API (for AI analysis)
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# X (Twitter) API Configuration
# ===========================================
X_BEARER_TOKEN=your_x_bearer_token_here
X_API_TIER=basic

# ===========================================
# Other Services
# ===========================================
# Resend API (Email service)
RESEND_API_KEY=your_resend_api_key_here

# Motion Plus (Premium animation library)
# After adding your token here, run:
#   npm install "https://api.motion.dev/registry.tgz?package=motion-plus&version=2.0.2&token=YOUR_TOKEN"
MOTION_PLUS_TOKEN=your_motion_plus_token_here

# ===========================================
# PostHog (Product Analytics)
# ===========================================
# Get your project API key from PostHog: Settings > Project > API Key
# PostHog is optional — if omitted, only Vercel Analytics runs.
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ===========================================
# Cloudinary (File uploads & image management)
# ===========================================
# Get these from your Cloudinary dashboard: Settings > Access Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# ===========================================
# Stripe (Payments & Subscriptions)
# ===========================================
# Get these from your Stripe dashboard: Developers > API keys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe Price IDs — create these in Stripe Dashboard > Products
STRIPE_PRICE_CREATOR_MONTHLY=price_creator_monthly_id
STRIPE_PRICE_CREATOR_ANNUAL=price_creator_annual_id
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual_id
STRIPE_PRICE_AGENCY_MONTHLY=price_agency_monthly_id
STRIPE_PRICE_AGENCY_ANNUAL=price_agency_annual_id
STRIPE_PRICE_DNA_REPORT=price_dna_report_id

# Enterprise inquiry notification email
ENTERPRISE_NOTIFY_EMAIL=team@mybrandos.app

# Cron job authorization
CRON_SECRET=your_cron_secret_here

# ===========================================
# Early Access Mode
# ===========================================
# When true, all visitors automatically get Inner Circle status
# Set to false (or remove) to require invite codes for new visitors
NEXT_PUBLIC_EARLY_ACCESS_MODE=true

# ===========================================
# Onchain / Blockchain (EAS Attestations)
# ===========================================
# Which chain to target for onchain attestations.
# Valid values: avalanche | avalanche-fuji | base | base-sepolia
# Default: avalanche-fuji (for hackathon development)
NEXT_PUBLIC_ONCHAIN_CHAIN=avalanche-fuji

# Platform wallet private key for signing attestations server-side.
# Generate: node -e "console.log('0x' + require('crypto').randomBytes(32).toString('hex'))"
# Fund with native gas token on the selected chain (AVAX for Avalanche, ETH for Base).
# Without this key, attestations run in simulation mode.
ONCHAIN_PLATFORM_PRIVATE_KEY=
